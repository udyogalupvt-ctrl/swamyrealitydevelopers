rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /properties/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blogPosts/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /faqs/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /galleryImages/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /testimonials/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /teamMembers/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }


    match /enquiries/{id} {
      // Public may submit an enquiry, with light server-side validation.
      allow create: if request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.mobile is string
        && request.resource.data.mobile.size() > 0
        && request.resource.data.message is string
        && request.resource.data.message.size() < 2000;
      // Only admins can read, update, or delete enquiries.
      allow read, update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false; // manage manually via Firebase Console
    }
  }
}
